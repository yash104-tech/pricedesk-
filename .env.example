# Copy this file to .env and fill in values from Supabase Dashboard → Project Settings → API
# Full guide: see SUPABASE_SETUP.md in this folder

# Your project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# anon public key (safe for browser — NOT the service_role key)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: run migrations from terminal (npm run setup:db)
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.idtnvquebjwkktqtfmc.supabase.co:5432/postgres

# Easier: paste supabase/RUN_ALL_IN_SUPABASE.sql in Supabase SQL Editor — see SETUP_NOW.md

# Optional: EmailJS credentials for automatic mail invites
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
